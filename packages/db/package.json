{
  "name": "@academy/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:push": "prisma db push --schema ./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ./prisma/schema.prisma",
    "db:seed": "tsx ./prisma/seed.ts",
    "db:sync-lesson-blocks": "tsx ../../scripts/sync-lesson-blocks.ts"
  },
  "prisma": {
    "seed": "tsx ./prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "prisma": "^7.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
