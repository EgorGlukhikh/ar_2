generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  AUTHOR
  CURATOR
  SALES_MANAGER
  STUDENT
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseDeliveryFormat {
  CLASSIC
  LIVE_COHORT
}

enum LessonType {
  TEXT
  VIDEO
  QUIZ
  HOMEWORK
  LIVE
  FILE
}

enum LessonContentBlockType {
  TEXT
  VIDEO
  FILE
  HOMEWORK
}

enum MediaSourceType {
  MANAGED_UPLOAD
  RUTUBE_EMBED
  CLOUD_IMPORT
  EXTERNAL_EMBED
}

enum VideoProviderType {
  MOCK
  CLOUDFLARE_STREAM
}

enum VideoAssetStatus {
  DRAFT
  PENDING_UPLOAD
  IMPORTING
  PROCESSING
  READY
  ERROR
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELED
}

enum OrderStatus {
  DRAFT
  PENDING
  PAID
  CANCELED
  REFUNDED
}

enum PaymentProviderType {
  DEMO
  MANUAL
  ROBOKASSA
  BANK131
  TBANK
}

enum PaymentStatus {
  CREATED
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum EmailProviderType {
  MOCK
  RESEND
}

enum EmailKind {
  TRANSACTIONAL
  MARKETING
}

enum EmailStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  FAILED
  BOUNCED
  COMPLAINED
  CANCELED
}

enum HomeworkSubmissionStatus {
  SUBMITTED
  IN_REVIEW
  REVISION_REQUESTED
  APPROVED
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  role          UserRole         @default(STUDENT)
  phone         String?
  telegram      String?
  city          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  accounts      Account[]
  sessions      Session[]
  authored      Course[]         @relation("CourseAuthor")
  enrollments   Enrollment[]
  progress      LessonProgress[]
  homework      HomeworkReview[] @relation("Reviewer")
  homeworkSubmissions HomeworkSubmission[] @relation("HomeworkStudentSubmissions")
  reviewedHomeworkSubmissions HomeworkSubmission[] @relation("HomeworkSubmissionReviewer")
  orders        Order[]
  emails        EmailMessage[]
  lessonSessions LessonSession[]
  workspaceInvitesSent WorkspaceInvite[] @relation("WorkspaceInviteSender")
  workspaceInvitesAccepted WorkspaceInvite[] @relation("WorkspaceInviteAccepter")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id             String               @id @default(cuid())
  slug           String               @unique
  title          String
  description    String?
  status         CourseStatus         @default(DRAFT)
  deliveryFormat CourseDeliveryFormat @default(CLASSIC)
  scheduleTimezone String             @default("Europe/Moscow")
  authorId       String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  author         User?                @relation("CourseAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  modules        Module[]
  enrollments    Enrollment[]
  products       Product[]
  emails         EmailMessage[]
  lessonSessions LessonSession[]
}

model Module {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@unique([courseId, position])
}

model Lesson {
  id                 String           @id @default(cuid())
  moduleId           String
  title              String
  excerpt            String?
  type               LessonType       @default(TEXT)
  position           Int
  isPreview          Boolean          @default(false)
  accessAfterDays    Int?
  content            Json?
  videoSourceType    MediaSourceType?
  videoUrl           String?
  videoPlaybackId    String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  module             Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress           LessonProgress[]
  lessonBlocks       LessonBlock[]
  homeworkAssignment HomeworkAssignment?
  videoAsset         VideoAsset?
  lessonSessions     LessonSession[]

  @@unique([moduleId, position])
}

model LessonBlock {
  id             String                 @id @default(cuid())
  lessonId       String
  blockKey       String
  type           LessonContentBlockType
  position       Int
  title          String
  body           String?
  url            String?
  note           String?
  submissionHint String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  lesson         Lesson                 @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, position])
  @@unique([lessonId, blockKey])
  @@index([lessonId, type])
}

model VideoAsset {
  id                     String            @id @default(cuid())
  lessonId               String            @unique
  provider               VideoProviderType @default(MOCK)
  sourceType             MediaSourceType
  status                 VideoAssetStatus  @default(DRAFT)
  originalFilename       String?
  mimeType               String?
  sizeInBytes            Int?
  externalAssetId        String?
  playbackId             String?
  playerUrl              String?
  uploadUrl              String?
  sourceUrl              String?
  requiresSignedPlayback Boolean           @default(false)
  metadata               Json?
  errorMessage           String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  lesson                 Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LessonProgress {
  id                  String   @id @default(cuid())
  userId              String
  lessonId            String
  completedAt         DateTime?
  lastPositionSeconds Int      @default(0)
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson              Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model HomeworkAssignment {
  id                    String           @id @default(cuid())
  lessonId              String           @unique
  instructions          String?
  requiresCuratorReview Boolean          @default(true)
  unlockNextModuleOnApproval Boolean     @default(true)
  allowTextSubmission   Boolean          @default(true)
  allowLinkSubmission   Boolean          @default(true)
  allowFileUpload       Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  lesson                Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  reviews               HomeworkReview[]
  submissions           HomeworkSubmission[]
}

model HomeworkReview {
  id           String             @id @default(cuid())
  assignmentId String
  studentId    String
  reviewerId   String?
  submission   Json?
  feedback     String?
  status       String             @default("submitted")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  assignment   HomeworkAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  reviewer     User?              @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([studentId])
}

model HomeworkSubmission {
  id                String                   @id @default(cuid())
  assignmentId      String
  studentId         String
  reviewerId        String?
  status            HomeworkSubmissionStatus @default(SUBMITTED)
  submissionText    String?
  submissionUrl     String?
  feedback          String?
  submittedAt       DateTime                 @default(now())
  reviewedAt        DateTime?
  approvedAt        DateTime?
  revisionRequestedAt DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  assignment        HomeworkAssignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student           User                     @relation("HomeworkStudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  reviewer          User?                    @relation("HomeworkSubmissionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  files             HomeworkSubmissionFile[]

  @@unique([assignmentId, studentId])
  @@index([status, updatedAt])
  @@index([studentId, updatedAt])
}

model HomeworkSubmissionFile {
  id          String               @id @default(cuid())
  submissionId String
  filename    String
  mimeType    String?
  sizeInBytes Int
  data        Bytes
  createdAt   DateTime             @default(now())
  submission  HomeworkSubmission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
}

model Product {
  id          String    @id @default(cuid())
  courseId    String?   @unique
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  course      Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  prices      Price[]
  orderItems  OrderItem[]
}

model Price {
  id         String   @id @default(cuid())
  productId  String
  amount     Int
  currency   String   @default("RUB")
  isDefault  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id              String              @id @default(cuid())
  userId          String?
  status          OrderStatus         @default(DRAFT)
  currency        String              @default("RUB")
  totalAmount     Int                 @default(0)
  paymentProvider PaymentProviderType @default(MANUAL)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  payments        Payment[]
  emails          EmailMessage[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int      @default(1)
  unitAmount Int
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Payment {
  id                String              @id @default(cuid())
  orderId           String
  provider          PaymentProviderType
  status            PaymentStatus       @default(CREATED)
  providerPaymentId String?
  paymentUrl        String?
  rawPayload        Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model EmailMessage {
  id                String            @id @default(cuid())
  userId            String?
  courseId          String?
  orderId           String?
  provider          EmailProviderType @default(MOCK)
  kind              EmailKind         @default(TRANSACTIONAL)
  status            EmailStatus       @default(QUEUED)
  templateKey       String
  campaignKey       String?
  sequenceStep      Int?
  dedupeKey         String?           @unique
  trackingToken     String            @unique
  subject           String
  fromEmail         String
  fromName          String?
  toEmail           String
  toName            String?
  htmlBody          String
  textBody          String?
  scheduledAt       DateTime          @default(now())
  sentAt            DateTime?
  deliveredAt       DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  failedAt          DateTime?
  providerMessageId String?
  lastError         String?
  metadata          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  course            Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  order             Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  user              User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  events            EmailEvent[]
  clicks            EmailLinkClick[]

  @@index([status, scheduledAt])
  @@index([userId, createdAt])
  @@index([courseId, createdAt])
}

model EmailEvent {
  id             String      @id @default(cuid())
  emailMessageId String
  eventType      String
  status         EmailStatus?
  providerId     String?
  payload        Json?
  createdAt      DateTime    @default(now())
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  @@index([emailMessageId, createdAt])
}

model EmailLinkClick {
  id             String       @id @default(cuid())
  emailMessageId String
  url            String
  createdAt      DateTime     @default(now())
  emailMessage   EmailMessage  @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  @@index([emailMessageId, createdAt])
}

model WorkspaceInvite {
  id           String    @id @default(cuid())
  email        String
  role         UserRole
  token        String    @unique
  note         String?
  invitedById  String
  acceptedById String?
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  invitedBy    User      @relation("WorkspaceInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy   User?     @relation("WorkspaceInviteAccepter", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([email, role, createdAt])
  @@index([expiresAt, revokedAt, acceptedAt])
}

model LessonSession {
  id                  String            @id @default(cuid())
  clientSessionId     String            @unique
  userId              String
  courseId            String
  lessonId            String
  actualRole          UserRole
  previewRole         UserRole?
  isPreview           Boolean           @default(false)
  sourceType          MediaSourceType?
  hadVideo            Boolean           @default(false)
  entryPath           String?
  lastPlayerState     String?
  exitReason          String?
  durationSeconds     Int?
  lastPositionSeconds Int               @default(0)
  maxPositionSeconds  Int               @default(0)
  startedAt           DateTime          @default(now())
  lastSeenAt          DateTime          @default(now())
  endedAt             DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  course              Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson              Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  events              LessonSessionEvent[]

  @@index([userId, createdAt])
  @@index([courseId, createdAt])
  @@index([lessonId, createdAt])
  @@index([actualRole, isPreview, createdAt])
}

model LessonSessionEvent {
  id              String         @id @default(cuid())
  lessonSessionId String
  eventType       String
  playerState     String?
  visibilityState String?
  positionSeconds Int?
  durationSeconds Int?
  payload         Json?
  createdAt       DateTime       @default(now())
  lessonSession   LessonSession  @relation(fields: [lessonSessionId], references: [id], onDelete: Cascade)

  @@index([lessonSessionId, createdAt])
  @@index([eventType, createdAt])
}
