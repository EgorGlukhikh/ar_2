{
  "name": "academy-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "dotenv -e .env -- npm run dev --workspace @academy/web",
    "build": "dotenv -e .env -- npm run build --workspace @academy/web",
    "lint": "dotenv -e .env -- npm run lint --workspace @academy/web",
    "typecheck": "npm run typecheck --workspace @academy/web",
    "smoke": "node ./scripts/smoke-routes.mjs",
    "railway:build": "npm run db:generate --workspace @academy/db && npm run build --workspace @academy/web",
    "railway:start": "npm run start --workspace @academy/web",
    "railway:release": "npm run db:generate --workspace @academy/db && npm run db:push --workspace @academy/db",
    "railway:bootstrap": "npm run db:seed --workspace @academy/db && npm run db:sync-lesson-blocks --workspace @academy/db",
    "railway:db:prepare": "npm run railway:release",
    "db:start": "docker compose up -d db",
    "db:stop": "docker compose down",
    "db:generate": "dotenv -e .env -- npm run db:generate --workspace @academy/db",
    "db:push": "dotenv -e .env -- npm run db:push --workspace @academy/db",
    "db:migrate": "dotenv -e .env -- npm run db:migrate --workspace @academy/db",
    "db:seed": "dotenv -e .env -- npm run db:seed --workspace @academy/db",
    "db:sync-lesson-blocks": "dotenv -e .env -- npm run db:sync-lesson-blocks --workspace @academy/db"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
